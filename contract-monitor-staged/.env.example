# Config file containing [[contracts]] entries
WATCHER_CONFIG=./config/example.toml

# Explorer / ABI fetching (Etherscan V2 multichain API)
WATCHER_EXPLORER_URL=https://api.etherscan.io/v2/api
WATCHER_EXPLORER_API_KEY=

# Chain / RPC
WATCHER_CHAIN_NAME=worldchain-staging
WATCHER_CHAIN_ID=480
WATCHER_WS_RPC_URL=wss://rpc.example

# Reconnect tuning
WATCHER_RECONNECT_INITIAL_BACKOFF_MS=1000
WATCHER_RECONNECT_MAX_BACKOFF_MS=30000

# Telemetry (via telemetry-batteries)
TELEMETRY_PRESET=datadog
TELEMETRY_SERVICE_NAME=contract-monitor
TELEMETRY_METRICS_BACKEND=statsd
TELEMETRY_STATSD_HOST=127.0.0.1
TELEMETRY_STATSD_PORT=8125
