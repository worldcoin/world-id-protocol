# Log level / filter (see tracing-subscriber EnvFilter syntax).
RUST_LOG=info

# Worker role to run: finalizer | payer
BILLING_ROLE=finalizer

# Address of the on-chain Billing Contract.
BILLING_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# HTTP RPC endpoints, comma-separated in priority order.
RPC_URL=https://worldchain-sepolia.g.alchemy.com/public

# Signer — exactly one of the following. The finalizer only needs a gas-funded
# key (finalizeEpochs is permissionless).
WALLET_PRIVATE_KEY=
# AWS_KMS_KEY_ID=
# AWS_KMS_KEY_IDS=

# Finalizer tuning (defaults shown).
# FINALIZER_MAX_STEPS_PER_TX=500
# FINALIZER_RECEIPT_TIMEOUT_SECS=60
# FINALIZER_CLOSE_LAG_SECS=3
# FINALIZER_CONFIRM_RETRY_INTERVAL_SECS=2
# FINALIZER_CONFIRM_MAX_ATTEMPTS=30
