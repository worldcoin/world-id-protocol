# Global Config
ENVIRONMENT=development
RUN_MODE=both
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres

# Indexer Config
RPC_URL=http://localhost:8545
REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
START_BLOCK=0
BATCH_SIZE=64
# Confirmation depth before events are committed to the DB. The in-memory tree
# is updated at the tip (proofs reflect unconfirmed updates); reorgs shallower
# than this are recovered in-memory without touching the DB.
CONFIRMATIONS=8
# Seconds to wait between RPC poll cycles once caught up
POLL_INTERVAL_SECS=2

# HTTP Config
HTTP_ADDR=0.0.0.0:8080
DB_POLL_INTERVAL_SECS=1

# Tree Cache Config (required)
TREE_CACHE_FILE=/data/tree.mmap
TREE_DEPTH=6
TREE_DENSE_PREFIX_DEPTH=2

# Optional: Configure dense prefix depth (default: 20)
# TREE_DENSE_PREFIX_DEPTH=20

# Optional: HttpOnly mode refresh interval in seconds (default: 30)
# TREE_HTTP_CACHE_REFRESH_INTERVAL_SECS=30
