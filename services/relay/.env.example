RELAY_CONFIG='{"source":{"chain_id":480,"world_id_source":"0xf2B281c1D115A0d3D19a4efCCDDe83dbB4DD23be","world_id_registry":"0x8556d07D75025f286fe757C7EeEceC40D54FA16D","oprf_key_registry":"0xb2C02253ee7bFEDF50F5D015658857099980E91F","issuer_schema_registry":"0x9037125Ae10e9E89fDbe7001228289462EFA3eF3","bridge_interval_secs":15},"permissioned_gateways":[{"name":"BASE","destination_chain_id":8453,"gateway":"0xd87a1be0C2aFB90906426b960a2aCDB1165d5426","satellite":"0xcC72Ca7BfB5E55613505EceBB6C97dA5E1131E21"}]}'

# Wallet private key for signing relay transactions on all chains, must be funded with ETH
